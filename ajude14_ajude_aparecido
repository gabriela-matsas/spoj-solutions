#AJUDE14 - Ajude Aparecido (https://br.spoj.com/problems/AJUDE14/)
while True:
    n = int(input("Quantas pessoas saíram?"))
    if n < 1 or n > 10:
        print("só é permitido um valor de 1 até 10, tente novamente")
    else:
        break

contas = []

for x in range(n):
    while True:
        ci = int(input("qual o valor da conta de cada pessoa"))
        if ci < 1 or ci > 100:
            print(" O valor só pode ser entre 1 e 100, tente novamente")
        else:
            contas.append(ci)
            break

while True:
    t = int(input("Digite o valor de cada conta das pessoas:"))
    if t < 1 or t > 5000:
        print("Só é permitido um valor entre 1 e 5000, tente novamente")
    else:
        break

if sum(contas) == t:
    print('Acertou')
else:
    print('Errou')
